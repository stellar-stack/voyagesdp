# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────

# Django core
OPENAI_API_KEY=your_openai_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — set USE_POSTGRES=True to switch from SQLite to PostgreSQL
USE_POSTGRES=False
DB_NAME=voyage
DB_USER=voyage_user
DB_PASSWORD=voyage_pass
DB_HOST=localhost
DB_PORT=5432

# Redis — used for caching and WebSocket channel layer
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT settings (seconds)
ACCESS_TOKEN_LIFETIME_SECONDS=900
REFRESH_TOKEN_LIFETIME_SECONDS=86400

# Social OAuth (free — no credit card)
# Google: https://console.cloud.google.com → APIs & Services → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
# GitHub: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3000/oauth/callback/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# AI Content Moderation
# Get your FREE key at https://platform.openai.com/api-keys
# The OpenAI Moderation endpoint is completely free — no credit card needed for it.
OPENAI_API_KEY=your_openai_api_key_here
# Email (for verification emails)
# For development: leave blank and emails print to the console
# For production: use SMTP credentials from Gmail / SendGrid / Mailgun
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@voyage.app

# Sentry error tracking (optional — get free DSN at sentry.io)
SENTRY_DSN=

# Media files (local storage)
MEDIA_ROOT=media

# Violation thresholds for AI auto-moderation
VIOLATION_WARN_THRESHOLD=2
VIOLATION_SUSPEND_7_THRESHOLD=3
VIOLATION_SUSPEND_30_THRESHOLD=5
VIOLATION_PERMANENT_BAN_THRESHOLD=7
